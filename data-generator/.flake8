[flake8]
max-line-length = 100
exclude = 
    __pycache__,
    .git,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info
ignore = 
    # whitespace before ':'
    E203,
    # blank line contains whitespace
    W293,
    # line break before binary operator
    W503,
per-file-ignores =
    __init__.py:F401
